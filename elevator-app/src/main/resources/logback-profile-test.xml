<!-- TEST logging: verbose and human-readable. Included by logback.xml when app.profile=test. -->
<included>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{36}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Kafka client coordination chatter stays quiet even here. -->
    <logger name="org.apache.kafka" level="WARN"/>
    <!-- Our own code at full detail. -->
    <logger name="pl.feelcodes.elevator" level="TRACE"/>

    <!-- Frameworks at DEBUG. Pekko's own event level is raised separately via PEKKO_LOGLEVEL
         (see application.conf) — logback alone can't lift Pekko's internal log filter. -->
    <root level="DEBUG">
        <appender-ref ref="CONSOLE"/>
    </root>
</included>
